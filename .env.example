# ============================================================
# PrepPal AI — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# --- Google AI ---
GOOGLE_API_KEY=your_gemini_api_key_here

# --- Database ---
DATABASE_URL=sqlite:///./data/preppal.db

# --- MCP Server ---
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=8001

# --- FastAPI Backend ---
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

# --- Streamlit Frontend ---
STREAMLIT_PORT=8501

# --- Application ---
APP_NAME=PrepPal AI
APP_VERSION=1.0.0
LOG_LEVEL=INFO
DEBUG=false

# --- CORS ---
CORS_ORIGINS=http://localhost:8501,http://localhost:3000
